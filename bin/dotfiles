#!/usr/bin/env bash
set -euo pipefail

OS=$(uname -s | tr '[:upper:]' '[:lower:]')

# resolve the rcm tag: darwin, or the specific linux distro (arch/ubuntu)
case "$OS" in
darwin)
  TAG='darwin'
  ;;
linux)
  TAG='unknown'
  if [[ -r /etc/os-release ]]; then
    TAG=$(. /etc/os-release && echo "$ID")
  fi
  ;;
*)
  TAG="$OS"
  ;;
esac

function update_rc_files() {
  rcup -fv \
    -x README.md \
    -x LICENSE \
    -x etc \
    -x script \
    -x public \
    -x claude/settings.json \
    -S config/nvim \
    -S docs \
    -t "$TAG"
}

function list_rc_files() {
  lsrc -v \
    -x README.md \
    -x LICENSE \
    -x etc \
    -x script \
    -x public \
    -x claude/settings.json \
    -S config/nvim \
    -S docs \
    -t "$TAG"
}

case "${1:-}" in
list)
  list_rc_files
  exit 0
  ;;
up)
  echo "Linking dotfiles..."
  update_rc_files
  exit 0
  ;;
*)
  echo "Manage dotfiles"
  echo ""
  echo -e "\e[32mUsage:\e[0m $(basename "$0") COMMAND"
  echo ""
  echo -e "\e[32mCommands:\e[0m"
  echo -e "\e[34mlist\e[0m          List dotfiles"
  echo -e "\e[34mup\e[0m            Update dotfiles"
  exit 1
  ;;
esac
